# Lines can be written either as KEY=VALUE or explicit SET commands.
# This file is intended for boot-time USB configuration injection.

TMC.IRUN=5
TMC.IHOLD=0
TMC.IHOLDDELAY=4
TMC.TPOWERDOWN=4
TMC.SGTHRS=4
BOOT.HOST_WAIT_MS=4000
MOTION.STEP_INTERVAL_US=250
MOTION.STEP_PULSE_US=4
LOGIC.STOP_ACTIVE_HIGH=0
LOGIC.DIR_INVERTED=1
PIN.X_UART=PE0
PIN.X_DIR=PE1
PIN.X_STEP=PE2
PIN.X_ENABLE=PE3
PIN.X_STOP=PC1
PIN.DIAG0=PC0
PIN.DIAG2=PC2
PIN.PS_ON=PE8
PIN.SAFE_POWER=PC13
PIN.LED=PE5

# Load-cell defaults stay simulated until real hardware is attached.
# Use LOADCELL.CONNECTOR for board-level presets instead of hand-entering MCU pins.
LOADCELL.SOURCE=SIMULATION
LOADCELL.CONNECTOR=CUSTOM
LOADCELL.THRESHOLD=1000
# Example HX711 presets:
# LOADCELL.CONNECTOR=SKR2_BLTOUCH
# LOADCELL.CONNECTOR=SKR2_DET
# Example conditioned analog presets:
# LOADCELL.CONNECTOR=SKR2_TH1